---
import Ironside from "../layouts/Ironside.astro";
---

<Ironside title="Polyaspartic garage floors" description="The Ironside polyaspartic system: diamond grind, polyaspartic basecoat, full-broadcast flake, aliphatic topcoat. UV-stable, hot-tire resistant, cures in 2 hours. Installed in one day, warranted for life." heroType="dark">

<!-- HERO (compact) -->
<section class="hero-dark compact">
  <div class="hero-img">
    <svg viewBox="0 0 1280 720" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id="kl2" cx="72%" cy="42%" r="48%"><stop offset="0%" stop-color="#E87A41" stop-opacity="0.32"/><stop offset="100%" stop-color="#0B0D10" stop-opacity="0"/></radialGradient>
        <linearGradient id="fl2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#1F2428"/><stop offset="100%" stop-color="#0B0D10"/></linearGradient>
      </defs>
      <rect width="1280" height="720" fill="#0B0D10"/><rect width="1280" height="720" fill="url(#kl2)"/>
      <rect x="0" y="420" width="1280" height="300" fill="url(#fl2)"/>
      <g fill="#B87333" opacity="0.5"><circle cx="300" cy="500" r="1.5"/><circle cx="600" cy="530" r="1.5"/><circle cx="900" cy="520" r="1.2"/><circle cx="1100" cy="560" r="1.5"/><circle cx="450" cy="600" r="1.2"/></g>
      <g fill="#6B7278" opacity="0.35"><circle cx="200" cy="550" r="1"/><circle cx="750" cy="480" r="1"/><circle cx="1000" cy="630" r="1"/></g>
    </svg>
  </div>
  <div class="hero-grad"></div><div class="hero-grain"></div>
  <div class="hero-inner">
    <div class="kicker mb-2">The flagship system</div>
    <h1 class="h-hero" style="max-width:16ch;margin-top:12px">Polyaspartic garage floors. Installed in a day. Warranted for life.</h1>
    <p class="lede" style="color:var(--color-iron-300);margin-top:28px;max-width:62ch">The Ironside System &mdash; diamond grind, polyaspartic basecoat, full-broadcast flake, aliphatic topcoat. UV-stable, hot-tire resistant, cures in 2&nbsp;hours.</p>
    <div style="display:flex;gap:12px;margin-top:40px;flex-wrap:wrap">
      <a href="/quote" class="btn btn-lg btn-primary">Get my free quote</a>
      <a href="#compare" class="btn btn-lg btn-ghost-dark">Compare to epoxy</a>
    </div>
  </div>
</section>

<!-- THE CHEMISTRY -->
<section class="section">
  <div class="container">
    <div class="split-64">
      <div>
        <div class="kicker">The chemistry</div>
        <h2 class="h1 mt-2" style="max-width:18ch">An aliphatic polyurea, evolved for flooring.</h2>
      </div>
      <p class="p" style="color:var(--fg2);max-width:52ch">Polyaspartic is an aliphatic polyurea with a deliberately slowed reaction. It cures in 2&nbsp;hours, stays optically clear under UV, and chemically bonds into diamond-ground concrete at a depth epoxy can&rsquo;t reach. We apply it at 12&ndash;14&nbsp;mil wet, two coats, with a full flake broadcast in between.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-top:48px">
      <div class="card">
        <div class="mono" style="font-size:32px;font-weight:500;color:var(--color-iron-950);letter-spacing:-.02em">2<span style="font-size:16px">h</span></div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-top:8px">Cure time</div>
        <div class="p" style="margin-top:12px;color:var(--fg2);font-size:13px">Epoxy cures in 18&ndash;72&nbsp;hours.</div>
      </div>
      <div class="card">
        <div class="mono" style="font-size:32px;font-weight:500;color:var(--color-iron-950);letter-spacing:-.02em">4&times;</div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-top:8px">Abrasion resist.</div>
        <div class="p" style="margin-top:12px;color:var(--fg2);font-size:13px">Taber abrasion vs std epoxy.</div>
      </div>
      <div class="card">
        <div class="mono" style="font-size:32px;font-weight:500;color:var(--color-iron-950);letter-spacing:-.02em">UV</div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-top:8px">Non-ambering</div>
        <div class="p" style="margin-top:12px;color:var(--fg2);font-size:13px">Aliphatic. Won&rsquo;t yellow through the bay door.</div>
      </div>
      <div class="card">
        <div class="mono" style="font-size:32px;font-weight:500;color:var(--color-iron-950);letter-spacing:-.02em">&minus;40&deg;</div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-top:8px">Temp range</div>
        <div class="p" style="margin-top:12px;color:var(--fg2);font-size:13px">Ontario winters, no problem.</div>
      </div>
    </div>
  </div>
</section>

<!-- POLYASPARTIC VS EPOXY -->
<section class="section section-dark" id="compare">
  <div class="container">
    <div class="kicker">Polyaspartic vs epoxy</div>
    <h2 class="h1 mt-2 mb-6" style="color:var(--fg-inverse);max-width:22ch">Two chemistries. Different use cases. We install both.</h2>

    <div style="background:var(--color-iron-900);border:1px solid var(--color-iron-800)">
      <table class="tbl" style="color:var(--fg-inverse)">
        <thead>
          <tr style="background:var(--color-iron-950)">
            <th style="color:var(--color-iron-300);background:transparent">Property</th>
            <th style="color:var(--accent);background:transparent">Polyaspartic</th>
            <th style="color:var(--color-iron-300);background:transparent">Epoxy</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-color:var(--color-iron-800)">
            <td style="border-color:var(--color-iron-800)">Cure time</td>
            <td class="mono" style="border-color:var(--color-iron-800)">2 hours</td>
            <td class="mono" style="border-color:var(--color-iron-800);color:var(--color-iron-300)">18&ndash;72 hours</td>
          </tr>
          <tr style="border-color:var(--color-iron-800)">
            <td style="border-color:var(--color-iron-800)">UV stability</td>
            <td class="mono" style="border-color:var(--color-iron-800)">Ambers never</td>
            <td class="mono" style="border-color:var(--color-iron-800);color:var(--color-iron-300)">Ambers in 6&ndash;12 mo</td>
          </tr>
          <tr style="border-color:var(--color-iron-800)">
            <td style="border-color:var(--color-iron-800)">Hot-tire resistance</td>
            <td class="mono" style="border-color:var(--color-iron-800)">Excellent</td>
            <td class="mono" style="border-color:var(--color-iron-800);color:var(--color-iron-300)">Fair</td>
          </tr>
          <tr style="border-color:var(--color-iron-800)">
            <td style="border-color:var(--color-iron-800)">Low-temp install</td>
            <td class="mono" style="border-color:var(--color-iron-800)">Down to &minus;5&deg;C</td>
            <td class="mono" style="border-color:var(--color-iron-800);color:var(--color-iron-300)">10&deg;C min</td>
          </tr>
          <tr style="border-color:var(--color-iron-800)">
            <td style="border-color:var(--color-iron-800)">Chemical resistance</td>
            <td class="mono" style="border-color:var(--color-iron-800)">Strong</td>
            <td class="mono" style="border-color:var(--color-iron-800);color:var(--color-iron-300)">Strong</td>
          </tr>
          <tr style="border-color:var(--color-iron-800)">
            <td style="border-color:var(--color-iron-800)">Install window</td>
            <td class="mono" style="border-color:var(--color-iron-800)">1 day</td>
            <td class="mono" style="border-color:var(--color-iron-800);color:var(--color-iron-300)">2 days</td>
          </tr>
          <tr>
            <td style="border-color:var(--color-iron-800)">Price range</td>
            <td class="mono" style="border-color:var(--color-iron-800)">$7&ndash;16 / ft&sup2;</td>
            <td class="mono" style="border-color:var(--color-iron-800);color:var(--color-iron-300)">$5&ndash;6 / ft&sup2;</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- FLAKE OPTIONS -->
<section class="section">
  <div class="container">
    <div class="kicker">Flake options</div>
    <h2 class="h1 mt-2 mb-6">12 standard blends. Custom on request.</h2>
    <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:16px">

      <!-- 01 Iron Forge -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #2E353B,#0B0D10);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#B87333" opacity="0.6"><circle cx="20" cy="30" r="1.5"/><circle cx="60" cy="50" r="1.5"/><circle cx="80" cy="20" r="1.2"/><circle cx="40" cy="70" r="1.3"/><circle cx="90" cy="80" r="1.5"/></g>
            <g fill="#6B7278" opacity="0.5"><circle cx="30" cy="60" r="1"/><circle cx="70" cy="85" r="1"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">01 &middot; IRON FORGE</div>
        <div class="caption">Charcoal &middot; copper &middot; graphite</div>
      </div>

      <!-- 02 Slate Salt -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #3a3a38,#1F2428);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#F4F3EF" opacity="0.55"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">02 &middot; SLATE SALT</div>
        <div class="caption">Slate &middot; white &middot; ash</div>
      </div>

      <!-- 03 Quarry -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #8a8579,#4a4740);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#2E353B" opacity="0.55"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">03 &middot; QUARRY</div>
        <div class="caption">Sand &middot; slate &middot; dark tan</div>
      </div>

      <!-- 04 Oakville -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #d4cdb8,#8a8268);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#4a4740" opacity="0.55"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">04 &middot; OAKVILLE</div>
        <div class="caption">Warm tan &middot; bone &middot; slate</div>
      </div>

      <!-- 05 Forge Ember -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #2a2e35,#0B0D10);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#D95F1F" opacity="0.5"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/></g>
            <g fill="#6B7278" opacity="0.5"><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">05 &middot; FORGE EMBER</div>
        <div class="caption">Black &middot; molten &middot; slate</div>
      </div>

      <!-- 06 Copper Mine -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #4a4740,#1a1d20);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#B87333" opacity="0.55"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">06 &middot; COPPER MINE</div>
        <div class="caption">Copper &middot; umber &middot; black</div>
      </div>

      <!-- 07 Cement -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #a8a5a0,#5a5a58);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#1F2428" opacity="0.55"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">07 &middot; CEMENT</div>
        <div class="caption">Concrete &middot; slate &middot; white</div>
      </div>

      <!-- 08 Mahogany -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #3a2828,#1a1010);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#d4a878" opacity="0.55"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">08 &middot; MAHOGANY</div>
        <div class="caption">Ox-blood &middot; tan &middot; black</div>
      </div>

      <!-- 09 Galaxy -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #1a1d20,#0B0D10);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#F4F3EF" opacity="0.35"><circle cx="25" cy="35" r="1"/><circle cx="65" cy="55" r="1.2"/><circle cx="85" cy="30" r="1"/><circle cx="45" cy="75" r="1"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">09 &middot; GALAXY</div>
        <div class="caption">Pure black &middot; micro white</div>
      </div>

      <!-- 10 Linen -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #d8d5cf,#9a978f);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#2E353B" opacity="0.4"><circle cx="25" cy="35" r="1.2"/><circle cx="65" cy="55" r="1.3"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">10 &middot; LINEN</div>
        <div class="caption">Bone &middot; slate &middot; silver</div>
      </div>

      <!-- 11 Blue Steel -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #2E353B,#131619);border:1px solid var(--color-iron-100);position:relative;overflow:hidden">
          <svg viewBox="0 0 100 100" style="position:absolute;inset:0;width:100%;height:100%">
            <g fill="#4A6B82" opacity="0.55"><circle cx="25" cy="35" r="1.3"/><circle cx="65" cy="55" r="1.5"/><circle cx="85" cy="30" r="1.2"/><circle cx="45" cy="75" r="1.2"/></g>
          </svg>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em">11 &middot; BLUE STEEL</div>
        <div class="caption">Steel &middot; indigo &middot; slate</div>
      </div>

      <!-- 12 Custom -->
      <div>
        <div style="aspect-ratio:1;background:radial-gradient(ellipse at 30% 30%, #4a4740,#2E353B);border:1px solid var(--color-iron-100);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center">
          <div class="mono" style="color:var(--color-copper-600);font-size:10px;letter-spacing:.14em;text-transform:uppercase;text-align:center">Custom<br/>Blend</div>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.1em;color:var(--color-copper-600)">12 &middot; CUSTOM</div>
        <div class="caption">Premium tier &mdash; your blend</div>
      </div>

    </div>
  </div>
</section>

<!-- WARRANTY SPOTLIGHT -->
<section class="section-copper section">
  <div class="container-narrow" style="text-align:center;position:relative;z-index:1">
    <div class="kicker plain" style="justify-content:center;display:inline-flex;color:var(--color-copper-600)">The Iron-Clad Warranty</div>
    <h2 class="h1 mt-2" style="color:var(--fg-inverse);max-width:20ch;margin:16px auto 0">Lifetime. Transferable. In writing.</h2>
    <p class="lede mt-4" style="color:var(--color-iron-300);margin-left:auto;margin-right:auto">Handed to you at project close. Covers adhesion, delamination, hot-tire pickup, and UV yellowing &mdash; for as long as you own the home, or the next owner does. One transfer. Backed by Penntek&rsquo;s manufacturer warranty behind ours.</p>
    <div style="display:flex;justify-content:center;gap:40px;margin-top:48px;flex-wrap:wrap">
      <div>
        <div class="mono" style="font-size:44px;font-weight:500;color:var(--color-copper-600);letter-spacing:-.02em;line-height:1">&infin;</div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--color-iron-300);margin-top:8px">Duration</div>
      </div>
      <div>
        <div class="mono" style="font-size:44px;font-weight:500;color:var(--color-copper-600);letter-spacing:-.02em;line-height:1">01</div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--color-iron-300);margin-top:8px">Transfer</div>
      </div>
      <div>
        <div class="mono" style="font-size:44px;font-weight:500;color:var(--color-copper-600);letter-spacing:-.02em;line-height:1">04</div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--color-iron-300);margin-top:8px">Failure modes covered</div>
      </div>
      <div>
        <div class="mono" style="font-size:44px;font-weight:500;color:var(--color-copper-600);letter-spacing:-.02em;line-height:1">PDF</div>
        <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--color-iron-300);margin-top:8px">Handed over</div>
      </div>
    </div>
  </div>
</section>

<!-- CTA BAND -->
<section class="cta-band">
  <div class="container">
    <div class="cta-band-inner">
      <div>
        <div class="kicker">Book your install</div>
        <h2 class="h1 mt-2" style="color:var(--fg-inverse);max-width:18ch">One floor. One day. Lifetime warranty.</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;align-items:flex-end">
        <a href="/quote" class="btn btn-lg btn-primary" style="min-width:260px">Get my free quote</a>
        <a href="tel:9055550174" class="btn btn-lg btn-ghost-dark" style="min-width:260px">905 &middot; 555 &middot; 0174</a>
      </div>
    </div>
  </div>
</section>

</Ironside>
