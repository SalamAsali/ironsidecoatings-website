        <div class="mono mt-2" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--fg3);display:flex;justify-content:space-between"><span>Glen Abbey &middot; Oakville</span><span>Mar 2026</span></div>
      </div>
      <div>
        <div class="ba">
          <div class="pane" style="background:#8a8f94"><span class="tag">Before</span></div>
          <div class="pane" style="background:radial-gradient(ellipse at 50% 30%, #2E353B, #0B0D10)"><span class="tag" style="background:var(--accent);color:var(--color-iron-950);border:0">After</span></div>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--fg3);display:flex;justify-content:space-between"><span>Shoreacres &middot; Burlington</span><span>Feb 2026</span></div>
      </div>
      <div>
        <div class="ba">
          <div class="pane" style="background:#6B7278"><span class="tag">Before</span></div>
          <div class="pane" style="background:radial-gradient(ellipse at 60% 40%, #2E353B, #0B0D10)"><span class="tag" style="background:var(--accent);color:var(--color-iron-950);border:0">After</span></div>
        </div>
        <div class="mono mt-2" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--fg3);display:flex;justify-content:space-between"><span>Bronte &middot; Oakville</span><span>Jan 2026</span></div>
      </div>
    </div>
  </div>
</section>

<!-- PRICING PREVIEW -->
<section class="section section-dark">
  <div class="container">
    <div style="text-align:center;margin-bottom:64px">
      <div class="kicker plain" style="justify-content:center;display:inline-flex">Pricing preview</div>
      <h2 class="h1 mt-2" style="max-width:20ch;margin:16px auto 0">Three tiers. One standard. Honest pricing.</h2>
    </div>
    <div class="tier-grid">
      <div class="tier">
        <div class="tier-name">Essential</div>
        <div class="pos">Single-car garage, clean slab, 1-color full broadcast.</div>
        <div class="price">$5&ndash;6<span style="font-size:14px;letter-spacing:.1em;margin-left:6px">/ ft&sup2;</span></div>
        <div class="price-sub">Starts at $2,500</div>
        <ul class="feat">
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Diamond grind prep</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>100% solids epoxy basecoat</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Urethane topcoat</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>5-year warranty</li>
        </ul>
        <a class="btn btn-md btn-ghost cta" href="/pricing">See details</a>
