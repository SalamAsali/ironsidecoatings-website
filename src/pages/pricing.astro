---
import Ironside from "../layouts/Ironside.astro";
---

<Ironside title="Pricing" description="Three tiers of polyaspartic and epoxy garage floor coating. Every Ironside tier includes diamond-grind prep, moisture testing, and a written warranty. Honest pricing, no bait quotes." heroType="light">

<!-- HERO -->
<section class="hero-light" style="padding-top:100px">
  <div class="inner">
    <div class="kicker">Pricing</div>
    <h1 class="h-hero mt-2" style="max-width:16ch">Three tiers. One standard. Honest pricing.</h1>
    <p class="lede mt-4">Every Ironside floor &mdash; Essential to Premium &mdash; includes diamond-grind prep, moisture testing, and a written warranty. The tiers differ in chemistry, flake depth, and warranty length. No phone quotes. No bait pricing.</p>
  </div>
</section>

<!-- TIER CARDS -->
<section class="section">
  <div class="container">
    <div class="tier-grid">

      <!-- Essential -->
      <div class="tier">
        <div class="tier-name">Essential</div>
        <div class="pos">Single-car garage, clean slab, 1-color full broadcast.</div>
        <div class="price">$5&ndash;6<span style="font-size:14px;letter-spacing:.1em;margin-left:6px">/ ft&sup2;</span></div>
        <div class="price-sub">Starts at $2,500</div>
        <ul class="feat">
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Diamond grind prep (CSP-2)</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>100% solids epoxy basecoat</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Urethane topcoat</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Partial flake broadcast</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>5-year warranty</li>
        </ul>
        <a class="btn btn-md btn-ghost cta" href="/quote">Get my quote</a>
      </div>

      <!-- Standard (highlighted) -->
      <div class="tier highlight">
        <div class="tier-flag">Most installed</div>
        <div class="tier-name">Standard</div>
        <div class="pos">Polyaspartic system, full-flake, 2-car garage, most popular.</div>
        <div class="price">$7&ndash;9<span style="font-size:14px;letter-spacing:.1em;margin-left:6px">/ ft&sup2;</span></div>
        <div class="price-sub">Starts at $4,200</div>
        <ul class="feat">
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Everything in Essential</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Polyaspartic basecoat + topcoat</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Full-broadcast vinyl flake (11 colors)</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>15-year warranty</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>1-day install window</li>
        </ul>
        <a class="btn btn-md btn-primary cta" href="/quote">Get my quote</a>
      </div>

      <!-- Premium -->
      <div class="tier premium">
        <div class="tier-badge">Ironside Premium</div>
        <div class="tier-name">Premium</div>
        <div class="pos">Iron-Clad Warranty, 2-coat topcoat, custom flake blend.</div>
        <div class="price">$10&ndash;16<span style="font-size:14px;letter-spacing:.1em;margin-left:6px">/ ft&sup2;</span></div>
        <div class="price-sub">Starts at $6,800</div>
        <ul class="feat">
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Everything in Standard</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Custom flake blend</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Double aliphatic topcoat</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Iron-Clad Lifetime Warranty</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 L10 18 L20 6"/></svg>Post-install care kit</li>
        </ul>
        <a class="btn btn-md btn-inverse cta" href="/quote">Book consult</a>
      </div>

    </div>
  </div>
</section>

<!-- INCLUDED IN EVERY TIER -->
<section class="section section-sm" style="background:var(--color-iron-50);border-top:1px solid var(--color-iron-100);border-bottom:1px solid var(--color-iron-100)">
  <div class="container">
    <div class="split-64">
      <div>
        <div class="kicker">Included in every tier</div>
        <h2 class="h2 mt-2">Ten things the cheap quote leaves out.</h2>
      </div>
      <p class="p" style="color:var(--fg2);max-width:50ch">Franchises and low-ball installers quote around prep. We quote it in every tier because skipping it is why floors fail. Here&rsquo;s what&rsquo;s always included, even on an Essential.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:40px">
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">01</span>
        <div class="h4" style="font-size:16px">Calcium-chloride moisture test</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">02</span>
        <div class="h4" style="font-size:16px">30-hp planetary diamond grind</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">03</span>
        <div class="h4" style="font-size:16px">Polyurea crack-chase fill</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">04</span>
        <div class="h4" style="font-size:16px">Joint honoring or hard-fill (your call)</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">05</span>
        <div class="h4" style="font-size:16px">Two-tech install crew</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">06</span>
        <div class="h4" style="font-size:16px">Photo updates at every step</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">07</span>
        <div class="h4" style="font-size:16px">Full-site HEPA vacuum</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">08</span>
        <div class="h4" style="font-size:16px">Written warranty + care instructions</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">09</span>
        <div class="h4" style="font-size:16px">$5M liability &middot; WSIB coverage</div>
      </div>
      <div class="card" style="padding:20px 24px;display:flex;gap:16px;align-items:center">
        <span class="mono text-accent" style="font-size:12px;letter-spacing:.14em">10</span>
        <div class="h4" style="font-size:16px">Post-install walkthrough</div>
      </div>
    </div>
  </div>
</section>

<!-- ADD-ONS & FINANCING -->
<section class="section">
  <div class="container">
    <div class="split-2">
      <div>
        <div class="kicker">Add-ons</div>
        <h2 class="h2 mt-2 mb-4">&Agrave; la carte, per sqft.</h2>
        <ul style="list-style:none;padding:0;margin:0">
          <li style="display:flex;justify-content:space-between;padding:20px 0;border-bottom:1px solid var(--color-iron-100)">
            <span class="h4" style="font-size:16px">Anti-slip aggregate</span>
            <span class="mono" style="color:var(--fg2)">+$0.60 / ft&sup2;</span>
          </li>
          <li style="display:flex;justify-content:space-between;padding:20px 0;border-bottom:1px solid var(--color-iron-100)">
            <span class="h4" style="font-size:16px">Cove base (6&Prime;)</span>
            <span class="mono" style="color:var(--fg2)">+$14 / ln ft</span>
          </li>
          <li style="display:flex;justify-content:space-between;padding:20px 0;border-bottom:1px solid var(--color-iron-100)">
            <span class="h4" style="font-size:16px">Heavy crack repair</span>
            <span class="mono" style="color:var(--fg2)">$120 &mdash; $400</span>
          </li>
          <li style="display:flex;justify-content:space-between;padding:20px 0;border-bottom:1px solid var(--color-iron-100)">
            <span class="h4" style="font-size:16px">Color stripe / logo</span>
            <span class="mono" style="color:var(--fg2)">$280 &mdash; $900</span>
          </li>
          <li style="display:flex;justify-content:space-between;padding:20px 0">
            <span class="h4" style="font-size:16px">Oil-stain deep clean</span>
            <span class="mono" style="color:var(--fg2)">$120 / bay</span>
          </li>
        </ul>
      </div>
      <div>
        <div class="kicker">Financing</div>
        <h2 class="h2 mt-2 mb-4">Financeable through Financeit.</h2>
        <div class="card-dark" style="background:var(--color-iron-950);border:1px solid var(--color-iron-800)">
          <div class="mono" style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--color-iron-300);margin-bottom:16px">Example &middot; Standard tier &middot; 600 ft&sup2;</div>
          <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:24px">
            <span class="mono" style="font-size:56px;font-weight:500;color:var(--fg-inverse);letter-spacing:-.02em">$89</span>
            <span class="mono" style="color:var(--color-iron-300);font-size:14px">/ mo &middot; 60 months &middot; 9.99% OAC</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;font-size:13px;color:var(--color-iron-300);border-top:1px solid var(--color-iron-800);padding-top:20px">
            <div>
              <div class="mono" style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--color-iron-500)">Total</div>
              <div class="mono mt-2" style="color:var(--fg-inverse);font-size:16px">$5,400</div>
            </div>
            <div>
              <div class="mono" style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--color-iron-500)">Approval</div>
              <div class="mono mt-2" style="color:var(--fg-inverse);font-size:16px">60 seconds</div>
            </div>
          </div>
          <a href="#" class="btn btn-md btn-primary mt-6" style="width:100%">Check rate</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA BAND -->
<section class="cta-band">
  <div class="container"><div class="cta-band-inner">
    <div>
      <div class="kicker">Book your install</div>
      <h2 class="h1 mt-2" style="color:var(--fg-inverse);max-width:18ch">Honest quote, one business day.</h2>
    </div>
    <div style="display:flex;flex-direction:column;gap:16px;align-items:flex-end">
      <a href="/quote" class="btn btn-lg btn-primary" style="min-width:260px">Get my free quote</a>
      <a href="tel:9055550174" class="btn btn-lg btn-ghost-dark" style="min-width:260px">905 &middot; 555 &middot; 0174</a>
    </div>
  </div></div>
</section>

</Ironside>
