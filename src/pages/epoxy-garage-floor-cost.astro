---
import Ironside from "../layouts/Ironside.astro";
---

<Ironside title="Epoxy garage floor cost in Ontario" description="Honest pricing for polyaspartic and epoxy garage floor coatings in Ontario. Budget epoxy $5&ndash;6/ft&sup2;, mid polyaspartic $7&ndash;9/ft&sup2;, Ironside premium $10&ndash;16/ft&sup2;. Interactive calculator included." heroType="light">

<!-- HERO -->
<section class="hero-light" style="padding-top:100px">
  <div class="inner">
    <div class="kicker">Cost guide &middot; Ontario</div>
    <h1 class="h-hero mt-3" style="max-width:22ch">What does a proper garage floor coating cost in Ontario?</h1>
    <p class="lede mt-4">Honest ranges. No bait-and-switch &ldquo;starting at&rdquo; quotes. Here&rsquo;s what you&rsquo;re actually paying for when a polyaspartic or epoxy floor is priced per square foot.</p>
  </div>
</section>

<!-- TL;DR BOX -->
<section class="section">
  <div class="container-narrow">
    <div style="background:var(--color-iron-950);color:var(--fg-inverse);padding:48px;border-left:4px solid var(--accent)">
      <div class="kicker" style="color:var(--accent)">TL;DR</div>
      <h2 class="h2 mt-3" style="color:var(--fg-inverse);max-width:24ch">Expect $5&ndash;16 per square foot installed. The gap is real and explainable.</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px">
        <div style="border-top:1px solid var(--color-iron-800);padding-top:20px">
          <div class="mono" style="font-size:12px;color:var(--color-iron-500);letter-spacing:.1em">BUDGET EPOXY</div>
          <div class="mono" style="font-size:32px;color:var(--fg-inverse);margin-top:8px">$5&ndash;6</div>
          <div class="mono" style="font-size:11px;color:var(--color-iron-300);margin-top:4px">/ ft&sup2; &middot; 1&ndash;2 yr warranty</div>
        </div>
        <div style="border-top:1px solid var(--color-iron-800);padding-top:20px">
          <div class="mono" style="font-size:12px;color:var(--color-iron-500);letter-spacing:.1em">MID POLYASPARTIC</div>
          <div class="mono" style="font-size:32px;color:var(--fg-inverse);margin-top:8px">$7&ndash;9</div>
          <div class="mono" style="font-size:11px;color:var(--color-iron-300);margin-top:4px">/ ft&sup2; &middot; 5&ndash;15 yr warranty</div>
        </div>
        <div style="border-top:2px solid var(--accent);padding-top:20px">
          <div class="mono" style="font-size:12px;color:var(--accent);letter-spacing:.1em">IRONSIDE PREMIUM</div>
          <div class="mono" style="font-size:32px;color:var(--fg-inverse);margin-top:8px">$10&ndash;16</div>
          <div class="mono" style="font-size:11px;color:var(--color-iron-300);margin-top:4px">/ ft&sup2; &middot; lifetime warranty</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SIX COST DRIVERS -->
<section class="section" style="padding-top:0">
  <div class="container">
    <div class="kicker">What drives the number</div>
    <h2 class="h2 mt-2 mb-8" style="max-width:22ch">Six factors &mdash; in order of impact.</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
      <div class="card" style="padding:28px">
        <div class="mono" style="font-size:11px;color:var(--accent);letter-spacing:.12em">01 &middot; HIGHEST IMPACT</div>
        <div class="h4" style="margin-top:12px">Prep method</div>
        <p class="p" style="margin-top:8px;color:var(--fg2)">Acid etch ($) vs diamond grind ($$$). Diamond grinding triples adhesion life. The cheapest single thing to compromise on &mdash; and the most dangerous.</p>
      </div>
      <div class="card" style="padding:28px">
        <div class="mono" style="font-size:11px;color:var(--accent);letter-spacing:.12em">02</div>
        <div class="h4" style="margin-top:12px">Coating chemistry</div>
        <p class="p" style="margin-top:8px;color:var(--fg2)">Epoxy ($) vs polyurea ($$) vs polyaspartic ($$$). Polyaspartic is 3&times; the raw material cost of budget epoxy and UV-stable where epoxy yellows.</p>
      </div>
      <div class="card" style="padding:28px">
        <div class="mono" style="font-size:11px;color:var(--accent);letter-spacing:.12em">03</div>
        <div class="h4" style="margin-top:12px">Slab condition</div>
        <p class="p" style="margin-top:8px;color:var(--fg2)">Cracks, pitting, oil contamination, moisture content &mdash; each adds remediation labour before the coating can even start.</p>
      </div>
      <div class="card" style="padding:28px">
        <div class="mono" style="font-size:11px;color:var(--accent);letter-spacing:.12em">04</div>
        <div class="h4" style="margin-top:12px">Coat count &amp; thickness</div>
        <p class="p" style="margin-top:8px;color:var(--fg2)">Single-coat &ldquo;flash&rdquo; jobs vs full 3-coat systems (primer + broadcast + topcoat). Thickness is warranty.</p>
      </div>
      <div class="card" style="padding:28px">
        <div class="mono" style="font-size:11px;color:var(--accent);letter-spacing:.12em">05</div>
        <div class="h4" style="margin-top:12px">Warranty terms</div>
        <p class="p" style="margin-top:8px;color:var(--fg2)">Lifetime transferable warranties require manufacturer-certified systems and certified applicators. That cost is real.</p>
      </div>
      <div class="card" style="padding:28px">
        <div class="mono" style="font-size:11px;color:var(--accent);letter-spacing:.12em">06</div>
        <div class="h4" style="margin-top:12px">Insurance &amp; licensing</div>
        <p class="p" style="margin-top:8px;color:var(--fg2)">$5M liability, WSIB coverage, and manufacturer certification add fixed overhead. Uninsured crews can undercut 30&ndash;40%.</p>
      </div>
    </div>
  </div>
</section>

<!-- INTERACTIVE CALCULATOR -->
<section class="section" style="background:var(--color-iron-950);color:var(--fg-inverse);padding:64px 0">
  <div class="container-narrow">
    <div class="kicker">Interactive &middot; rough estimate</div>
    <h2 class="h2 mt-2 mb-4" style="color:var(--fg-inverse);max-width:20ch">Ballpark my garage.</h2>
    <p class="lede" style="color:var(--color-iron-300);max-width:56ch">Not a quote. A ballpark for your planning spreadsheet. Final price requires a site visit + moisture test.</p>

    <div style="background:var(--color-iron-900);border:1px solid var(--color-iron-800);padding:40px;margin-top:32px;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center">
      <div>
        <div style="margin-bottom:28px">
          <label class="mono" style="font-size:11px;letter-spacing:.12em;color:var(--color-iron-300);display:block;margin-bottom:12px">GARAGE SIZE</label>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            <button class="pill" data-size="1">1-car &middot; 240ft&sup2;</button>
            <button class="pill active" data-size="2">2-car &middot; 440ft&sup2;</button>
            <button class="pill" data-size="3">3-car &middot; 680ft&sup2;</button>
            <button class="pill" data-size="4">Larger &middot; 900ft&sup2;</button>
          </div>
        </div>
        <div>
          <label class="mono" style="font-size:11px;letter-spacing:.12em;color:var(--color-iron-300);display:block;margin-bottom:12px">TIER</label>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            <button class="pill" data-rate="5.5">Essential</button>
            <button class="pill active" data-rate="8">Standard</button>
            <button class="pill" data-rate="13">Premium</button>
          </div>
        </div>
      </div>
      <div style="text-align:center;border-left:1px solid var(--color-iron-800);padding-left:48px">
        <div class="mono" style="font-size:11px;letter-spacing:.12em;color:var(--color-iron-300)">BALLPARK RANGE</div>
        <div id="est" class="mono" style="font-size:56px;color:var(--fg-inverse);margin-top:8px;line-height:1;letter-spacing:-.02em">$3,300 &ndash; $3,700</div>
        <div id="rate" class="mono" style="font-size:13px;color:var(--accent);margin-top:12px">$7.50&ndash;$8.50 / ft&sup2; &middot; 440 ft&sup2;</div>
        <a href="/quote" class="btn btn-md btn-primary" style="margin-top:24px">Get my exact quote</a>
      </div>
    </div>
  </div>
</section>

<!-- WHAT CHEAP QUOTES HIDE vs WHAT IRONSIDE INCLUDES -->
<section class="section">
  <div class="container">
    <div class="split-64" style="align-items:start">
      <div>
        <div class="kicker" style="color:var(--color-danger)">Fair warning</div>
        <h2 class="h2 mt-2" style="max-width:22ch">What a $3/ft&sup2; quote actually hides.</h2>
        <div style="display:grid;gap:16px;margin-top:32px">
          <div class="list-row"><span class="x">&times;</span><div><div class="h4" style="font-size:18px">Acid etching instead of diamond grinding</div><div class="p" style="color:var(--fg2);margin-top:4px">Cheaper, faster, and peels within 3 years.</div></div></div>
          <div class="list-row"><span class="x">&times;</span><div><div class="h4" style="font-size:18px">Single-coat &ldquo;flash&rdquo; system</div><div class="p" style="color:var(--fg2);margin-top:4px">Half the dry-film thickness of a proper 3-coat job.</div></div></div>
          <div class="list-row"><span class="x">&times;</span><div><div class="h4" style="font-size:18px">No moisture test</div><div class="p" style="color:var(--fg2);margin-top:4px">Trapped moisture delaminates the coat &mdash; usually year 2.</div></div></div>
          <div class="list-row"><span class="x">&times;</span><div><div class="h4" style="font-size:18px">1-year warranty on labour only</div><div class="p" style="color:var(--fg2);margin-top:4px">Manufacturer material warranties are void without a certified applicator.</div></div></div>
          <div class="list-row"><span class="x">&times;</span><div><div class="h4" style="font-size:18px">Cash-only, no WSIB</div><div class="p" style="color:var(--fg2);margin-top:4px">If a crew member is injured on your property, your homeowner&rsquo;s insurance pays.</div></div></div>
        </div>
      </div>
      <div>
        <div class="kicker">What Ironside&rsquo;s pricing includes</div>
        <h2 class="h2 mt-2" style="max-width:22ch">Every tier, every time.</h2>
        <div style="display:grid;gap:16px;margin-top:32px">
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">Diamond grind prep</div></div></div>
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">Calcium chloride moisture test</div></div></div>
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">Crack &amp; joint repair with polyurea</div></div></div>
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">3-coat manufacturer-certified system</div></div></div>
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">Branded crew, photo updates</div></div></div>
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">$5M liability, WSIB, certified applicator</div></div></div>
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">Post-install care package</div></div></div>
          <div class="list-row"><span class="c">&check;</span><div><div class="h4" style="font-size:18px">Transferable Iron-Clad Warranty paperwork</div></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DECISION MATRIX -->
<section class="section section-dark">
  <div class="container">
    <div class="kicker">Do I need polyaspartic?</div>
    <h2 class="h2 mt-2 mb-8" style="color:var(--fg-inverse);max-width:20ch">Decision matrix.</h2>
    <div style="background:var(--color-iron-900);border:1px solid var(--color-iron-800)">
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;padding:16px 24px;border-bottom:1px solid var(--color-iron-800)" class="mono">
        <div style="font-size:11px;letter-spacing:.12em;color:var(--color-iron-300)">YOUR SITUATION</div>
        <div style="font-size:11px;letter-spacing:.12em;color:var(--color-iron-300);text-align:center">EPOXY</div>
        <div style="font-size:11px;letter-spacing:.12em;color:var(--accent);text-align:center">POLYASPARTIC</div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;padding:20px 24px;border-bottom:1px solid var(--color-iron-800);align-items:center">
        <div>South-facing garage with direct sun</div>
        <div style="text-align:center;color:var(--fg3)">Yellows</div>
        <div style="text-align:center;color:var(--accent)">&check;</div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;padding:20px 24px;border-bottom:1px solid var(--color-iron-800);align-items:center">
        <div>Need truck back in &le;24h</div>
        <div style="text-align:center;color:var(--fg3)">No</div>
        <div style="text-align:center;color:var(--accent)">&check;</div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;padding:20px 24px;border-bottom:1px solid var(--color-iron-800);align-items:center">
        <div>Winter salt &amp; hot-tire pickup risk</div>
        <div style="text-align:center;color:var(--fg3)">Struggles</div>
        <div style="text-align:center;color:var(--accent)">&check;</div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;padding:20px 24px;border-bottom:1px solid var(--color-iron-800);align-items:center">
        <div>Rental unit, 5-year horizon, tight budget</div>
        <div style="text-align:center;color:var(--accent)">&check;</div>
        <div style="text-align:center;color:var(--fg3)">Overkill</div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;padding:20px 24px;align-items:center">
        <div>Forever home, forever floor</div>
        <div style="text-align:center;color:var(--fg3)">No</div>
        <div style="text-align:center;color:var(--accent)">&check;</div>
      </div>
    </div>
  </div>
</section>

<!-- CTA BAND -->
<section class="cta-band">
  <div class="container">
    <div class="cta-band-inner">
      <div>
        <div class="kicker">Get an exact number</div>
        <h2 class="h1 mt-2" style="color:var(--fg-inverse);max-width:20ch">Written quote in 48 hours.</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;align-items:flex-end">
        <a href="/quote" class="btn btn-lg btn-primary" style="min-width:260px">Get my free quote</a>
        <a href="/pricing" class="btn btn-lg btn-ghost-dark" style="min-width:260px">See pricing tiers</a>
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  const state={size:440,rate:8};
  function fmt(n){return '$'+Math.round(n).toLocaleString()}
  function fmtRate(r){return '$'+(r-.5).toFixed(2)+'\u2013$'+(r+.5).toFixed(2)+' / ft\u00B2 \u00B7 '+state.size+' ft\u00B2'}
  function update(){
    const low=state.size*(state.rate-.5), high=state.size*(state.rate+.5);
    document.getElementById('est').textContent=fmt(low)+' \u2013 '+fmt(high);
    document.getElementById('rate').textContent=fmtRate(state.rate);
  }
  document.querySelectorAll('[data-size]').forEach(function(b){
    b.onclick=function(){
      document.querySelectorAll('[data-size]').forEach(function(x){x.classList.remove('active')});
      b.classList.add('active');
      var s=+b.dataset.size;
      state.size=s===1?240:s===2?440:s===3?680:900;
      update();
    };
  });
  document.querySelectorAll('[data-rate]').forEach(function(b){
    b.onclick=function(){
      document.querySelectorAll('[data-rate]').forEach(function(x){x.classList.remove('active')});
      b.classList.add('active');
      state.rate=+b.dataset.rate;
      update();
    };
  });
})();
</script>

</Ironside>
