---
import Ironside from "../../layouts/Ironside.astro";
---

<Ironside title="Service areas" description="Ironside Coatings services Oakville, Burlington, Milton, Hamilton, Ancaster, Stoney Creek, and West Mississauga. Tight geography, deep local knowledge." heroType="light">

<!-- HERO -->
<section class="hero-light" style="padding-top:100px">
  <div class="inner">
    <div class="kicker">Service areas</div>
    <h1 class="h-hero mt-2" style="max-width:18ch">Epoxy flooring across GTA West, based in Oakville.</h1>
    <p class="lede mt-4">We service a 40-minute radius around our Oakville shop. Tight geography, deep local knowledge &mdash; we know which subdivisions were poured on high-chloride slabs and plan accordingly.</p>
  </div>
</section>

<!-- COVERAGE MAP + CITY CARDS -->
<section class="section">
  <div class="container">
    <div class="split-64" style="align-items:start">
      <div>
        <div class="kicker">Coverage map</div>
        <h2 class="h2 mt-2 mb-4">Six cities. One crew.</h2>
        <div style="aspect-ratio:4/3;background:var(--color-iron-950);border:1px solid var(--color-iron-800);position:relative;overflow:hidden">
          <svg viewBox="0 0 500 380" style="width:100%;height:100%">
            <defs><pattern id="g2" width="24" height="24" patternUnits="userSpaceOnUse"><path d="M24 0L0 0L0 24" fill="none" stroke="#1F2428" stroke-width="0.5"/></pattern></defs>
            <rect width="500" height="380" fill="#0B0D10"/><rect width="500" height="380" fill="url(#g2)"/>
            <path d="M0 260 Q125 275 250 265 Q375 255 500 275 L500 380 L0 380 Z" fill="#131619"/>
            <text x="250" y="340" text-anchor="middle" font-family="JetBrains Mono" font-size="11" fill="#6B7278" letter-spacing="3">LAKE ONTARIO</text>
            <circle cx="250" cy="200" r="145" fill="none" stroke="#D95F1F" stroke-width="1" stroke-dasharray="4 5" opacity="0.5"/>
            <g font-family="JetBrains Mono" font-size="11" fill="#F4F3EF">
              <circle cx="250" cy="200" r="8" fill="#D95F1F"/><text x="266" y="204" font-weight="600">Oakville &middot; HQ</text>
              <circle cx="170" cy="210" r="4" fill="#E87A41"/><text x="155" y="230" text-anchor="middle" fill="#B8BCC0">Burlington</text>
              <circle cx="220" cy="130" r="4" fill="#E87A41"/><text x="220" y="118" text-anchor="middle" fill="#B8BCC0">Milton</text>
              <circle cx="100" cy="220" r="4" fill="#E87A41"/><text x="85" y="240" text-anchor="middle" fill="#B8BCC0">Hamilton</text>
              <circle cx="120" cy="170" r="4" fill="#E87A41"/><text x="105" y="158" text-anchor="middle" fill="#B8BCC0">Ancaster</text>
              <circle cx="340" cy="185" r="4" fill="#E87A41"/><text x="352" y="188" fill="#B8BCC0">Mississauga</text>
              <circle cx="60" cy="245" r="4" fill="#E87A41"/><text x="48" y="262" text-anchor="middle" fill="#B8BCC0">Stoney Creek</text>
            </g>
          </svg>
        </div>
      </div>

      <div>
        <div class="kicker">City pages</div>
        <h2 class="h2 mt-2 mb-4">Drill in.</h2>
        <div style="display:flex;flex-direction:column;gap:12px">
          <a href="/service-areas/oakville" class="card" style="display:flex;justify-content:space-between;align-items:center;text-decoration:none;color:inherit">
            <div><div class="h4" style="font-size:18px">Oakville</div><div class="mono" style="font-size:11px;color:var(--fg3);letter-spacing:.1em;margin-top:4px">HQ &middot; 8 NEIGHBORHOODS</div></div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/service-areas/burlington" class="card" style="display:flex;justify-content:space-between;align-items:center;text-decoration:none;color:inherit">
            <div><div class="h4" style="font-size:18px">Burlington</div><div class="mono" style="font-size:11px;color:var(--fg3);letter-spacing:.1em;margin-top:4px">15-MIN FROM HQ</div></div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/service-areas/milton" class="card" style="display:flex;justify-content:space-between;align-items:center;text-decoration:none;color:inherit">
            <div><div class="h4" style="font-size:18px">Milton</div><div class="mono" style="font-size:11px;color:var(--fg3);letter-spacing:.1em;margin-top:4px">25-MIN FROM HQ</div></div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/service-areas/hamilton" class="card" style="display:flex;justify-content:space-between;align-items:center;text-decoration:none;color:inherit">
            <div><div class="h4" style="font-size:18px">Hamilton</div><div class="mono" style="font-size:11px;color:var(--fg3);letter-spacing:.1em;margin-top:4px">30-MIN FROM HQ</div></div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/service-areas/ancaster" class="card" style="display:flex;justify-content:space-between;align-items:center;text-decoration:none;color:inherit">
            <div><div class="h4" style="font-size:18px">Ancaster</div><div class="mono" style="font-size:11px;color:var(--fg3);letter-spacing:.1em;margin-top:4px">35-MIN FROM HQ</div></div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/service-areas/mississauga" class="card" style="display:flex;justify-content:space-between;align-items:center;text-decoration:none;color:inherit">
            <div><div class="h4" style="font-size:18px">Mississauga <span class="badge badge-accent" style="margin-left:8px">West only</span></div><div class="mono" style="font-size:11px;color:var(--fg3);letter-spacing:.1em;margin-top:4px">CLARKSON &middot; LORNE PARK</div></div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- NOT IN THESE CITIES -->
<section class="section section-sm" style="background:var(--color-iron-50);border-top:1px solid var(--color-iron-100);border-bottom:1px solid var(--color-iron-100)">
  <div class="container">
    <div class="kicker">Not in these cities?</div>
    <h2 class="h2 mt-2 mb-4" style="max-width:20ch">We&rsquo;re tight on purpose.</h2>
    <p class="lede" style="max-width:70ch">Outside the radius we refer you to a vetted partner rather than send a crew 90 minutes down the 401. Oakville, Burlington, Milton, Hamilton, Ancaster, Stoney Creek, and West Mississauga are our confirmed service zones. Send us a note and we&rsquo;ll point you at someone we trust.</p>
    <a href="/quote" class="btn btn-md btn-secondary mt-4">Check my postal code</a>
  </div>
</section>

<!-- CTA BAND -->
<section class="cta-band">
  <div class="container">
    <div class="cta-band-inner">
      <div>
        <div class="kicker">Ready to book</div>
        <h2 class="h1 mt-2" style="color:var(--fg-inverse);max-width:20ch">Get a quote for your city.</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;align-items:flex-end">
        <a href="/quote" class="btn btn-lg btn-primary" style="min-width:260px">Get my free quote</a>
        <a href="tel:9055550174" class="btn btn-lg btn-ghost-dark" style="min-width:260px">905 &middot; 555 &middot; 0174</a>
      </div>
    </div>
  </div>
</section>

</Ironside>
